{
  "name": "@loykin/datasourcekit",
  "version": "0.0.0-dev",
  "description": "Datasource plugin registry and execution layer for Loykin dashboard, alert, and reporting runtimes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit && tsup",
    "build:js": "tsup",
    "dev": "concurrently \"tsup --watch\" \"pnpm playground\"",
    "playground": "pnpm --dir playground dev",
    "playground:build": "pnpm --dir playground build",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "datasource",
    "query",
    "executor",
    "data",
    "plugin"
  ],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
